<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="16dp">

    <!-- Description tâche -->
    <TextView
        android:id="@+id/txtTask"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Tâche d’assemblage"
        android:textSize="28sp"
        android:textStyle="bold"
        android:fontFamily="@font/bebas_neue"
        android:textColor="@android:color/black"
        android:gravity="center"
        android:layout_marginBottom="12dp"/>

    <!-- Image assemblage -->
    <ImageView
        android:id="@+id/imgAssembly"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:scaleType="fitCenter"
        android:layout_marginTop="8dp"
        android:layout_marginBottom="8dp"/>

    <!-- Ligne boutons -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical">

        <ImageButton
            android:id="@+id/btnHelp"
            android:layout_width="200dp"
            android:layout_height="200dp"
            android:layout_gravity="center_horizontal"
            android:src="@drawable/bouton_aide"
            android:background="@drawable/help_button_selector"
            android:padding="30dp"
            android:scaleType="fitCenter"
            android:elevation="8dp"
            android:contentDescription="Demande d'aide"/>

        <!-- Encadré demande de pièces -->
        <LinearLayout
            android:id="@+id/partsBox"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@drawable/parts_box_background"
            android:visibility="gone"
            android:layout_marginStart="24dp"
            android:padding="2dp">

            <!-- Titre -->
            <TextView
                android:id="@+id/txtPartsTitle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Demande de pièces"
                android:textSize="26sp"
                android:textStyle="bold"
                android:fontFamily="@font/bebas_neue"
                android:textColor="@android:color/black"
                android:layout_gravity="center"
                android:layout_marginBottom="8dp"/>

            <!-- Conteneur des boutons -->
            <LinearLayout
                android:id="@+id/partsContainer"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center"/>

        </LinearLayout>

    </LinearLayout>


</LinearLayout>